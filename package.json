{
  "name": "video-forge",
  "version": "1.0.0",
  "description": "Generate professional marketing videos from code. Designed as a Claude Code skill.",
  "main": "src/index.js",
  "bin": {
    "vforge": "./bin/vforge.js"
  },
  "scripts": {
    "start": "node bin/vforge.js",
